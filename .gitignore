# ---- Rust (core/) ----
/core/target/
**/target/
**/*.rs.bk
*.pdb

# ---- Swift (app/) ----
/app/.build/
**/.build/
.swiftpm/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
.swift-version

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ---- Editors / IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.fleet/

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
*.p12

# ---- ClaudeStudio runtime data (never commit) ----
*.sock
qdrant-data/
sessions.db
sessions.db-*
~/.claudestudio/

# ---- Build-Loop Test-Harness Evidence (Screenshots/Logs, kann groß sein) ----
test-harness/evidence/*
!test-harness/evidence/.gitkeep

# ---- Build-Loop Wegwerf-Test-Projekte (eigene nested git-Repos, von Probes erzeugt) ----
test-harness/projects/*
!test-harness/projects/.gitkeep

# ---- Logs / misc ----
*.log
node_modules/
dist/
tmp/
test-harness/lib/ttsprobe
test-harness/lib/whisper-models/

# ---- Playwright MCP Artefakte (Screenshots/Traces) ----
.playwright-mcp/
